# Database (Turso) — leave as file:local.db for local development
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Better Auth — required
# Generate a strong random secret (e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET=change-this-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — required (used for verification + password reset + drift alerts)
RESEND_API_KEY=
EMAIL_FROM="Portfolio Tracker <portfolio@resend.dev>"

# One-shot multi-user migration: address to use as the legacy owner.
# Falls back to settings.email if a row exists. Only used by `npm run migrate:multiuser`.
OWNER_EMAIL=

# Cron auth — server-to-server bearer for /api/cron/*
CRON_SECRET=change-this-to-a-random-string

# IMAP — for auto-importing CMC email confirmations (optional)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
